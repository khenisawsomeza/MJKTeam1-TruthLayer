{
  "manifest_version": 3,
  "name": "TruthLayer",
  "version": "2.1.0",
  "description": "Click to analyze any article's credibility with AI-powered fake news detection.",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "16": "TruthLayerLogo.png",
    "48": "TruthLayerLogo.png",
    "128": "TruthLayerLogo.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "TruthLayer - Check Credibility",
    "default_icon": "TruthLayerLogo.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.facebook.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ]
    }
  ]
}