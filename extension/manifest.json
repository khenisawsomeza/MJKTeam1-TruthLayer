{
  "manifest_version": 3,
  "name": "TruthLayer",
  "version": "2.0.0",
  "description": "Click to analyze any article's credibility with AI-powered fake news detection.",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "TruthLayer - Check Credibility"
  },
  "background": {
    "service_worker": "background.js"
  }
}
