{
  "manifest_version": 3,
  "name": "TruthLayer",
  "version": "2.1.0",
  "description": "Click to analyze any article's credibility with AI-powered fake news detection. Results should be used as guidance.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "16": "assets/TruthLayerLogo48.png",
    "48": "assets/TruthLayerLogo48.png",
    "128": "assets/TruthLayerLogo128.png"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "TruthLayer - Check Credibility",
    "default_icon": "assets/TruthLayerLogo48.png"
  },
  "background": {
    "service_worker": "src/background/index.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.facebook.com/*"
      ],
      "js": [
        "src/content/facebookContent.js"
      ],
      "css": [
        "styles/facebook.css"
      ]
    }
  ]
}
